---
layout: default
---

{% if page._styles %}
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<!-- EQUALS sub-navigation -->
<div class="equals-subnav" style="background-color: #f8f9fa; border-bottom: 1px solid #dee2e6; margin-bottom: 2rem;">
  <div class="container">
    <nav class="nav py-2">
      <a class="nav-link fw-bold me-3" href="/equals/">🔬 EQUALS</a>
      <a class="nav-link" href="/equals/">About</a>
      <a class="nav-link" href="/equals/team/">Team</a>
      <a class="nav-link" href="/equals/publications/">Publications</a>
      <a class="nav-link" href="/equals/resources/">Resources</a>
      <a class="nav-link" href="/equals/news/">News</a>
      <a class="nav-link" href="/equals/contact/">Contact</a>
      <a class="nav-link" href="/">About the PI ↗</a>
    </nav>
  </div>
</div>

<!-- Page content -->
<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>
  <article>
    {{ content }}
  </article>
</div>