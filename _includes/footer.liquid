{% capture footer_contents %}
  <span style="white-space: nowrap;">&copy; Copyright {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}.</span>
  {% if site.impressum_path %}<a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.{% endif %}
  <span style="white-space: nowrap;">The EQUALS project is funded by the ANR &mdash; <a href="https://anr.fr/Projet-ANR-25-CE03-5866/" target="_blank" rel="noopener">ANR-25-CE03-5866</a>.</span>
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}
